import tkinter as tk
from tkinter import messagebox
from datetime import datetime
import tkinter.font as tkFont

FILE_NAME = "log.txt"
def Current_time():
    current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    label_time.config(text=current_time)
    label_time.after(1000,Current_time)
# โหลดข้อมูล
def load_tasks():
    tasks = []
    try:
        with open(FILE_NAME, "r") as f:
            for line in f:
                tasks.append(line.strip())
    except FileNotFoundError:
        pass
    return tasks

# บันทึกไฟล์
def save_tasks():
    with open(FILE_NAME, "w") as f:
        for task in tasks:
            f.write(task + "\n")

# เพิ่มงาน (เพิ่มเวลา)
def add_task():
    task = entry.get()
    if task:
        current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        tasks.append(f"[ ] {task} ({current_time})")
        entry.delete(0, tk.END)
        update_listbox()
        save_tasks()
    else:
        messagebox.showwarning("Warning", "กรุณาใส่งาน")

# ลบงาน
def remove_task():
    selected = listbox.curselection()
    if not selected:
        messagebox.showwarning("Warning", "กรุณาเลือกงาน")
        return

    # ลบจากหลังไปหน้า (กัน index เพี้ยน)
    for index in reversed(selected):
        tasks.pop(index)

    update_listbox()
    save_tasks()

# ทำเสร็จ
def mark_done():
    try:
        selected = listbox.curselection()[0]
        tasks[selected] = tasks[selected].replace("[ ]", "[Success]")
        update_listbox()
        save_tasks()
    except:
        messagebox.showwarning("Warning", "กรุณาเลือกงาน")

# แสดงรายการ
def update_listbox():
    listbox.delete(0, tk.END)
    for task in tasks:
        listbox.insert(tk.END, task)

# ===== GUI =====
root = tk.Tk()
root.title("To-Do List")
label_time = tk.Label(root, text="", font=("Arial", 18))  
label_time.pack()
Current_time()
tasks = load_tasks()

entry = tk.Entry(root, width=40)
entry.pack(pady=10)

btn_frame = tk.Frame(root)
btn_frame.pack()

btn_font = tkFont.Font(size=12, weight="bold")
tk.Button(btn_frame, text="Add", width=7,font=btn_font, command=add_task).grid(row=0, column=0)
tk.Button(btn_frame, text="Remove", width=7,font=btn_font, command=remove_task).grid(row=0, column=1)
tk.Button(btn_frame, text="Done", width=7,font=btn_font, command=mark_done).grid(row=0, column=2)

tk.Label(root, text="todo List").pack(pady=7)
listbox = tk.Listbox(root, width=60, selectmode=tk.MULTIPLE)
listbox.pack(pady=10)

update_listbox()

root.mainloop()